---
import OperatorStamp from './OperatorStamp.astro';
import SocialRow from './SocialRow.astro';
---
<footer class="site-footer">
  <div class="container-wide footer-grid">
    <div>
      <a href="/" class="footer-logo">
        Clueless Creations<sup style="font-size:.5em; vertical-align:super;">®</sup>
      </a>
      <p class="muted footer-tag">
        A business that runs businesses. Humans on the board; the harness on the floor.
      </p>
    </div>
    <div>
      <div class="eyebrow footer-heading">Explore</div>
      <ul class="footer-links">
        <li><a href="/about" class="footer-link">How it works</a></li>
        <li><a href="/about-me" class="footer-link">About me</a></li>
        <li><a href="/contact" class="footer-link">Reach us</a></li>
      </ul>
    </div>
    <div>
      <div class="eyebrow footer-heading">Build</div>
      <ul class="footer-links">
        <li><a href="https://github.com/Clueless-Creations" target="_blank" rel="noopener" class="footer-link">GitHub <span style="opacity:.5;">↗</span></a></li>
      </ul>
    </div>
    <div>
      <div class="eyebrow footer-heading">Follow</div>
      <SocialRow />
    </div>
  </div>

  <div class="container-wide">
    <hr class="divider-hairline" />
    <div class="footer-stamp-row">
      <OperatorStamp />
      <div class="operator-stamp">THIS SITE WAS ASSEMBLED BY THE OPERATOR, NOT A HUMAN.</div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-14) 0 var(--space-10);
    border-top: 1px solid var(--color-border);
    background: var(--surface-base);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: var(--space-8);
    }
  }
  .footer-logo {
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    font-size: var(--text-heading-sm);
    color: var(--color-fg);
    text-decoration: none;
    letter-spacing: 0.005em;
  }
  .footer-tag {
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
    margin-top: var(--space-3);
    max-width: 24rem;
  }
  .footer-heading { margin-bottom: var(--space-4); }
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer-link {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: var(--color-fg); }
  .footer-stamp-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-4);
  }
</style>
