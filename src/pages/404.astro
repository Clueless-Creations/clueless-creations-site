---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  page="404"
  title="Not found — Clueless Creations"
  description="The page you were looking for isn't here. Head home."
>
  <section class="section" style="min-height: calc(100vh - 200px); display: flex; align-items: center;">
    <div class="container-wide" style="text-align: center; max-width: 36rem; margin: 0 auto;">
      <div class="eyebrow" style="margin-bottom: var(--space-6);">404</div>
      <h1 class="heading-lg" style="margin: 0 0 var(--space-8);">
        That one <span class="muted">got away.</span>
      </h1>
      <p class="subheading muted" style="margin: 0 0 var(--space-14);">
        The page you wanted isn't here. Head back to the portfolio or reach out.
      </p>
      <a href="/" class="btn-primary">Home →</a>
    </div>
  </section>
</BaseLayout>
