---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialRow from '../components/SocialRow.astro';
---
<BaseLayout
  page="about-me"
  title="About me — Eduardo Muth-Martinez"
  description="Founder note from the human on the board of Clueless Creations."
>
  <section style="padding: 8rem 1.5rem 4rem; background: hsl(var(--background));">
    <div class="container-wide" style="max-width: 42rem;">
      <div class="eyebrow" style="margin-bottom: var(--space-4);">Founder note</div>
      <h1 class="display-xl font-display" style="margin: 0 0 var(--space-12); line-height: 0.95;">
        The human
        <em class="accent-muted">on the board.</em>
      </h1>

      <picture>
        <source srcset="/img/eduardo.avif" type="image/avif" />
        <img
          src="/img/eduardo.jpg"
          alt="Eduardo Muth-Martinez"
          width="640"
          height="854"
          loading="lazy"
          decoding="async"
          style="width: 100%; aspect-ratio: 3/4; max-width: 18rem; border-radius: var(--radius-lg); margin: 0 0 var(--space-12); object-fit: cover; display: block;"
        />
      </picture>

      <div class="bio prose" style="font-family: var(--font-body); font-size: 1.0625rem; line-height: 1.75; color: hsl(var(--foreground) / 0.88);">
        <p style="margin: 0 0 1.25rem;">
          I run a portfolio of businesses through an agent harness. Each one
          is a bet that software can discover, validate, build, launch, and
          operate products with minimal human oversight — and that the lessons
          from running them compound into better harness, better products,
          better distribution.
        </p>
        <p style="margin: 0 0 1.25rem;">
          I write about this every week at
          <a href="https://www.thecompoundingfounder.com/" target="_blank" rel="noopener" style="color: inherit; text-decoration: underline; text-decoration-color: hsl(var(--muted-foreground)); text-underline-offset: 3px;">The Compounding Founder</a>:
          <em>build once, extract forever.</em> Notes from a solo founder
          turning work into compounding assets.
        </p>
        <p style="margin: 0;">
          Best way to reach me is email. Slow on DMs, fast on substantive email.
        </p>
      </div>

      <div style="margin-top: var(--space-12); padding-top: var(--space-8); border-top: 1px solid rgba(255,255,255,0.08);">
        <div class="eyebrow" style="margin-bottom: var(--space-4);">Reach me</div>
        <SocialRow />
      </div>
    </div>
  </section>
</BaseLayout>
