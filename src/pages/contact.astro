---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialRow from '../components/SocialRow.astro';
---
<BaseLayout
  page="contact"
  title="Reach us — Clueless Creations"
  description="Contact the board at Clueless Creations. Operators, investors, fellow travelers."
>
  <section class="section" style="min-height: calc(100vh - 200px); display: flex; align-items: center;">
    <div class="container-wide" style="max-width: 42rem; margin: 0 auto; text-align: center;">
      <div class="eyebrow" style="margin-bottom: var(--space-6);">Reach the board</div>
      <h1 class="heading-lg" style="margin: 0 0 var(--space-14);">
        <span class="muted">Operators,</span> investors, <span class="muted">fellow travelers.</span>
      </h1>
      <p class="subheading muted" style="margin: 0 0 var(--space-14); max-width: 36rem; margin-inline: auto;">
        The fastest way to reach the board is email. For everything else, the social links below.
      </p>
      <a href="mailto:eduardo@clueless-creations.com" class="btn-primary" style="margin-bottom: var(--space-14);">
        eduardo@clueless-creations.com
      </a>
      <div style="display: flex; justify-content: center; margin-top: var(--space-10);">
        <SocialRow />
      </div>
    </div>
  </section>
</BaseLayout>
